{
  "mcpServers": {
    "context7": {
      "command": "/home/raka/.nvm/versions/node/v20.20.2/bin/node",
      "args": [
        "/home/raka/mcp-servers/context7/packages/mcp/dist/index.js"
      ]
    },
    "desktop-commander": {
      "command": "/home/raka/.nvm/versions/node/v20.20.2/bin/node",
      "args": [
        "/home/raka/mcp-servers/DesktopCommanderMCP/dist/index.js"
      ],
      "alwaysAllow": [
        "read_multiple_files",
        "edit_block",
        "read_file",
        "list_directory",
        "write_file",
        "create_directory",
        "start_search",
        "start_process",
        "move_file",
        "get_file_info",
        "list_processes",
        "interact_with_process",
        "read_process_output",
        "list_sessions",
        "force_terminate"
      ]
    },

    "playwright": {
      "command": "/home/raka/.nvm/versions/node/v20.20.2/bin/node",
      "args": [
        "/home/raka/mcp-servers/playwright-mcp/packages/playwright-mcp/cli.js",
        "--hydra",
        "--caps=storage"
      ]
    },

    "github": {
      "command": "/home/raka/mcp-servers/github-mcp-server/github-mcp-server",
      "args": [
        "stdio",
        "--tools",
        "github_list_activity,github_understand_codebase,github_execute_workflow,github_manage_thread,get_me,search_repositories,search_code,get_file_contents,delete_file,push_files,issue_write,add_issue_comment,pull_request_read,merge_pull_request,create_branch,list_branches,list_commits,create_repository"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_PERSONAL_ACCESS_TOKEN"
      },
      "alwaysAllow": [
        "github_understand_codebase"
      ]
    },
    "youtube-transcript": {
      "command": "/home/raka/.local/bin/uv",
      "args": [
        "--directory",
        "/home/raka/mcp-servers/mcp-youtube-transcript",
        "run",
        "mcp-youtube-transcript"
      ]
    },
    "chrome-devtools": {
      "command": "/home/raka/.nvm/versions/node/v20.20.2/bin/node",
      "args": [
        "/home/raka/mcp-servers/chrome-devtools-mcp/build/src/bin/chrome-devtools-mcp.js"
      ]
    },
    "agentic-testing": {
      "command": "/home/raka/.local/bin/uv",
      "args": [
        "--directory",
        "/home/raka/mcp-servers/agentic-testing",
        "run",
        "agentic-testing"
      ]
    },
    "notebooklm": {
      "command": "/home/raka/.local/bin/uv",
      "args": [
        "--directory",
        "/home/raka/mcp-servers/notebooklm-mcp-cli",
        "run",
        "notebooklm-mcp"
      ]
    },
    "auto-linter": {
      "command": "/home/raka/.local/bin/uv",
      "args": [
        "--directory",
        "/home/raka/mcp-servers/auto_linter",
        "run",
        "auto-linter"
      ],
      "env": {
        "DESKTOP_COMMANDER_URL": "/tmp/dc.sock",
        "PHANTOM_ROOT": "/home/raka/"
      },
      "alwaysAllow": [
        "lint",
        "execute_command",
        "health_check",
        "list_commands",
        "read_skill_context"
      ]
    }
  }
}